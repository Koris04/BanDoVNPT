<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Đăng nhập - Hệ thống giám sát mạng lưới VNPT</title>
    <link rel="icon" type="image/png" href="/images/Mini%20logo.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { 
            background-color: #f8f9fa;
            display: flex; flex-direction: column; min-height: 100vh; margin: 0;
        }
        .bg-vnpt { background-color: #0072BC !important; }
        .login-card { 
            width: 100%; max-width: 600px;
            border: none; border-radius: 12px; 
            box-shadow: 0 15px 40px rgba(0, 114, 188, 0.15); 
        }
    </style>
</head>
<body>
    
    <%- include('partials/banner') %>

    <div class="flex-grow-1 d-flex align-items-center justify-content-center p-3">
        <div class="card login-card p-5 bg-white">
            
            <div class="text-center mb-5">
                <h5 class="text-secondary fw-bold mb-2">HỆ THỐNG GIÁM SÁT MẠNG LƯỚI</h5>
                <h1 class="fw-bolder" style="color: #004a8f; font-size: 2.8rem; letter-spacing: 2px;">ĐĂNG NHẬP</h1>
            </div>

            <% if (typeof error !== 'undefined' && error.length > 0) { %>
                <div class="alert alert-danger py-3 text-center fw-bold fs-6"><%= error %></div>
            <% } %>

            <form action="/dangnhap" method="POST">
                <div class="mb-4">
                    <label class="form-label fw-bold text-muted fs-5">Tên đăng nhập</label>
                    <input type="text" name="username" class="form-control form-control-lg bg-light" 
                           placeholder="?????" autofocus 
                           value="<%= typeof oldUsername !== 'undefined' ? oldUsername : '' %>">
                </div>
                <div class="mb-5">
                    <label class="form-label fw-bold text-muted fs-5">Mật khẩu</label>
                    <input type="password" name="password" class="form-control form-control-lg bg-light" placeholder="*****">
                </div>
                <button type="submit" class="btn bg-vnpt text-white w-100 fw-bold py-3 fs-5 rounded-3 shadow-sm">ĐĂNG NHẬP</button>
            </form>

        </div>
    </div>

    <%- include('partials/footer') %>

</body>
</html>