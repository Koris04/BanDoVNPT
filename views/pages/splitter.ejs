<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
        <h3 class="text-primary fw-bold mb-0"><i class="bi bi-hdd-rack text-danger"></i> QUẢN LÝ SPLITTER/Tủ PON</h3>
    </div>
    <div>
        <button class="btn bg-vnpt text-white fw-bold shadow-sm" data-bs-toggle="modal"
            data-bs-target="#modalThemSplitter">
            <i class="bi bi-plus-circle"></i> Thêm Splitter
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="text-center py-3">STT</th>
                        <th class="py-3">Tên tủ</th>
                        <th class="py-3 text-center">Loại</th>
                        <th class="py-3">SysID</th>
                        <th class="py-3">Nguồn cáp</th>
                        <th class="py-3 text-center">Trạng thái</th>
                        <th class="py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof danhSachSplitter !=='undefined' && danhSachSplitter.length> 0) { %>
                        <% danhSachSplitter.forEach(function(sp, index) { %>
                            <tr>
                                <td class="text-center text-muted fw-bold">
                                    <%= (currentPage - 1) * 10 + index + 1 %>
                                </td>
                                <td><span class="fw-bold text-dark"><i class="bi bi-hdd-network"></i>
                                        <%= sp.ten_splitter %>
                                    </span></td>
                                <td class="text-center">
                                    <% if(sp.loai_splitter==='1:4' ) { %>
                                        <span class="badge bg-primary px-2 py-1">Cấp 1 (<%= sp.loai_splitter %>)</span>
                                        <% } else { %>
                                            <span class="badge bg-info text-dark px-2 py-1">Cấp 2 (<%= sp.loai_splitter
                                                    %>)</span>
                                            <% } %>
                                </td>
                                <td class="text-danger fw-bold">
                                    <%= sp.sys_id %>
                                </td>
                                <td>
                                    <% if(sp.splitter_cha_id) { %>
                                        <span class="text-primary fw-bold">
                                            <%= sp.splitter_cha_id.ten_splitter %>
                                        </span>
                                        <% } else { %>
                                            <span class="text-success fw-bold"><i class="bi bi-server"></i> Nối thẳng
                                                trạm OLT</span>
                                            <% } %>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-success rounded-pill">
                                        <%= sp.trang_thai %>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-warning shadow-sm me-1" title="Sửa thông tin"
                                        onclick="chuanBiSuaSplitter('<%= sp._id %>', '<%= sp.ten_splitter %>', '<%= sp.sys_id %>', <%= sp.vi_tri.coordinates[1] %>, <%= sp.vi_tri.coordinates[0] %>, '<%= sp.loai_splitter %>', '<%= sp.splitter_cha_id ? sp.splitter_cha_id._id : '' %>')"
                                        data-bs-toggle="modal" data-bs-target="#modalSuaSplitter">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <form action="/quanly/splitter/xoa/<%= sp._id %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Cảnh báo: Bạn có chắc chắn muốn xóa Tủ PON này? Dữ liệu sẽ không thể khôi phục!');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm"
                                            title="Xóa tủ">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            Chưa có tủ Splitter nào trong CSDL.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
    <nav aria-label="Page navigation" class="mt-4 mb-2">
        <ul class="pagination justify-content-center shadow-sm" style="border-radius: 8px;">
            <li class="page-item <%= currentPage == 1 ? 'disabled' : '' %>">
                <a class="page-link" href="/quanly/splitter?page=<%= parseInt(currentPage) - 1 %>">Trước</a>
            </li>

            <% for(let i=1; i <=totalPages; i++) { %>
                <li class="page-item <%= currentPage == i ? 'active' : '' %>">
                    <a class="page-link <%= currentPage == i ? 'bg-vnpt border-vnpt text-white fw-bold' : 'text-primary' %>"
                        href="/quanly/splitter?page=<%= i %>">
                        <%= i %>
                    </a>
                </li>
                <% } %>

                    <li class="page-item <%= currentPage == totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="/quanly/splitter?page=<%= parseInt(currentPage) + 1 %>">Sau</a>
                    </li>
        </ul>
    </nav>
    <% } %>
        <div class="modal fade" id="modalThemSplitter" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-vnpt text-white">
                        <h5 class="modal-title fw-bold"><i class="bi bi-node-plus"></i> THÊM TỦ PON</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form action="/quanly/splitter/them" method="POST">
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên tủ</label>
                                <input type="text" name="ten_splitter" class="form-control"
                                    placeholder="VD: Tủ cấp 1 - Nguyễn Thái Học..." required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">SysID</label>
                                <input type="text" name="sys_id" class="form-control text-danger fw-bold"
                                    value="AGG-LX-01" required>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold text-danger">
                                    <i class="bi bi-geo-alt-fill"></i> Vị trí<span class="text-danger">*</span>
                                </label>

                                <div class="input-group mb-2 shadow-sm">
                                    <span class="input-group-text bg-light fw-bold text-secondary">Vĩ độ</span>
                                    <input type="number" step="any" name="vi_do" id="vi_do_splitter"
                                        class="form-control text-primary fw-bold" required readonly>

                                    <span class="input-group-text bg-light fw-bold text-secondary">Kinh độ</span>
                                    <input type="number" step="any" name="kinh_do" id="kinh_do_splitter"
                                        class="form-control text-primary fw-bold" required readonly>
                                </div>

                                <div id="map-splitter" style="height: 300px; border-radius: 8px; z-index: 1;"
                                    class="border border-primary shadow-sm"></div>
                                <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle"></i> Gợi ý: Người
                                    dùng có
                                    thể nhấn giữ và kéo thả điểm ghim màu xanh để tinh chỉnh vị trí.</small>
                            </div>

                            <hr>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-primary">Loại tủ</label>
                                <select name="loai_splitter" id="loai_splitter" class="form-select border-primary"
                                    required onchange="kiemTraLoaiSplitter()">
                                    <option value="1:4">Cấp 1 (Chia 1:4) - Nối thẳng OLT</option>
                                    <option value="1:16">Cấp 2 (Chia 1:16) - Nối từ tủ Cấp 1</option>
                                </select>
                            </div>

                            <div class="mb-3 d-none bg-light p-3 border rounded" id="khung_splitter_cha">
                                <label class="form-label fw-bold text-danger"><i class="bi bi-link-45deg"></i> Nối
                                    vào tủ Cấp 1 nào?</label>
                                <select name="splitter_cha_id" class="form-select">
                                    <option value="">-- Chọn tủ nguồn --</option>
                                    <% if (typeof danhSachSplitterCap1 !=='undefined' ) { %>
                                        <% danhSachSplitterCap1.forEach(function(sp) { %>
                                            <option value="<%= sp._id %>">
                                                <%= sp.ten_splitter %> (<%= sp.sys_id %>)
                                            </option>
                                            <% }); %>
                                                <% } %>
                                </select>
                            </div>

                        </div>
                        <div class="modal-footer bg-light">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn bg-vnpt text-white fw-bold shadow-sm"><i
                                    class="bi bi-floppy"></i>
                                Lưu Tủ</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="modal fade" id="modalSuaSplitter" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square"></i> CẬP NHẬT TỦ PON</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form id="formSuaSplitter" method="POST">
                        <div class="modal-body p-4">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Tên tủ</label>
                                <input type="text" name="ten_splitter" id="sua_ten_splitter"
                                    class="form-control border-warning" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">SysID</label>
                                <input type="text" name="sys_id" id="sua_sys_id"
                                    class="form-control text-danger fw-bold" required>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold text-danger">
                                    <i class="bi bi-geo-alt-fill"></i> Vị trí<span class="text-danger">*</span>
                                </label>
                                <div class="input-group mb-2 shadow-sm">
                                    <span class="input-group-text bg-light fw-bold text-secondary">Vĩ độ</span>
                                    <input type="number" step="any" name="vi_do" id="sua_vi_do"
                                        class="form-control text-primary fw-bold" required readonly>
                                    <span class="input-group-text bg-light fw-bold text-secondary">Kinh độ</span>
                                    <input type="number" step="any" name="kinh_do" id="sua_kinh_do"
                                        class="form-control text-primary fw-bold" required readonly>
                                </div>
                                <div id="map-splitter-sua" style="height: 300px; border-radius: 8px; z-index: 1;"
                                    class="border border-primary shadow-sm"></div>
                            </div>
                            <hr>
                            <div class="mb-3">
                                <label class="form-label fw-bold text-primary">Loại tủ</label>
                                <select name="loai_splitter" id="sua_loai_splitter" class="form-select border-primary"
                                    required onchange="kiemTraLoaiSplitterSua()">
                                    <option value="1:4">Cấp 1 (Chia 1:4) - Nối thẳng OLT</option>
                                    <option value="1:16">Cấp 2 (Chia 1:16) - Nối từ tủ Cấp 1</option>
                                </select>
                            </div>
                            <div class="mb-3 bg-light p-3 border rounded" id="sua_khung_splitter_cha">
                                <label class="form-label fw-bold text-danger"><i class="bi bi-link-45deg"></i> Nối vào
                                    tủ Cấp 1 nào?</label>
                                <select name="splitter_cha_id" id="sua_splitter_cha_id" class="form-select">
                                    <option value="">-- Chọn tủ nguồn --</option>
                                    <% if (typeof danhSachSplitterCap1 !=='undefined' ) { %>
                                        <% danhSachSplitterCap1.forEach(function(sp) { %>
                                            <option value="<%= sp._id %>">
                                                <%= sp.ten_splitter %> (<%= sp.sys_id %>)
                                            </option>
                                            <% }); %>
                                                <% } %>
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer bg-light">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-warning fw-bold shadow-sm"><i class="bi bi-floppy"></i>
                                Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            function kiemTraLoaiSplitterSua() {
                var loai = document.getElementById('sua_loai_splitter').value;
                var khungCha = document.getElementById('sua_khung_splitter_cha');
                if (loai === '1:16') {
                    khungCha.classList.remove('d-none');
                } else {
                    khungCha.classList.add('d-none');
                }
            }

            let mapSuaSplitter;
            let markerSuaSplitter;
            let currentLatSua = 10.3759;
            let currentLngSua = 105.4333;

            function chuanBiSuaSplitter(id, ten, sys_id, lat, lng, loai, cha_id) {
                document.getElementById('formSuaSplitter').action = '/quanly/splitter/sua/' + id;

                document.getElementById('sua_ten_splitter').value = ten;
                document.getElementById('sua_sys_id').value = sys_id;
                document.getElementById('sua_loai_splitter').value = loai;
                document.getElementById('sua_vi_do').value = lat;
                document.getElementById('sua_kinh_do').value = lng;

                document.getElementById('sua_splitter_cha_id').value = cha_id || '';

                kiemTraLoaiSplitterSua();

                currentLatSua = lat;
                currentLngSua = lng;

                if (mapSuaSplitter && markerSuaSplitter) {
                    let newLatLng = new L.LatLng(lat, lng);
                    markerSuaSplitter.setLatLng(newLatLng);
                    mapSuaSplitter.setView(newLatLng, 17);
                }
            }

            document.getElementById('modalSuaSplitter').addEventListener('shown.bs.modal', function () {
                if (!mapSuaSplitter) {
                    mapSuaSplitter = L.map('map-splitter-sua').setView([currentLatSua, currentLngSua], 17);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; OpenStreetMap'
                    }).addTo(mapSuaSplitter);

                    markerSuaSplitter = L.marker([currentLatSua, currentLngSua], { draggable: true }).addTo(mapSuaSplitter);

                    mapSuaSplitter.on('click', function (e) {
                        markerSuaSplitter.setLatLng([e.latlng.lat, e.latlng.lng]);
                        document.getElementById('sua_vi_do').value = e.latlng.lat;
                        document.getElementById('sua_kinh_do').value = e.latlng.lng;
                    });

                    markerSuaSplitter.on('dragend', function (e) {
                        const position = markerSuaSplitter.getLatLng();
                        document.getElementById('sua_vi_do').value = position.lat;
                        document.getElementById('sua_kinh_do').value = position.lng;
                    });
                } else {
                    mapSuaSplitter.invalidateSize();
                }
            });
        </script>

        <script>
            function kiemTraLoaiSplitter() {
                var loai = document.getElementById('loai_splitter').value;
                var khungCha = document.getElementById('khung_splitter_cha');
                if (loai === '1:16') {
                    khungCha.classList.remove('d-none');
                } else {
                    khungCha.classList.add('d-none');
                }
            }

            let mapSplitter;
            let markerSplitter;

            document.getElementById('modalThemSplitter').addEventListener('shown.bs.modal', function () {

                if (!mapSplitter) {
                    const defaultLat = 10.3759;
                    const defaultLng = 105.4333;

                    mapSplitter = L.map('map-splitter').setView([defaultLat, defaultLng], 14);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; OpenStreetMap contributors'
                    }).addTo(mapSplitter);

                    markerSplitter = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(mapSplitter);

                    document.getElementById('vi_do_splitter').value = defaultLat;
                    document.getElementById('kinh_do_splitter').value = defaultLng;

                    mapSplitter.on('click', function (e) {
                        const lat = e.latlng.lat;
                        const lng = e.latlng.lng;

                        markerSplitter.setLatLng([lat, lng]);

                        document.getElementById('vi_do_splitter').value = lat;
                        document.getElementById('kinh_do_splitter').value = lng;
                    });

                    markerSplitter.on('dragend', function (e) {
                        const position = markerSplitter.getLatLng();
                        document.getElementById('vi_do_splitter').value = position.lat;
                        document.getElementById('kinh_do_splitter').value = position.lng;
                    });

                } else {
                    mapSplitter.invalidateSize();
                }
            });
        </script>