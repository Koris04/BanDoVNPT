<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
        <h3 class="text-primary fw-bold mb-0"><i class="bi bi-router text-danger"></i> DANH SÁCH ĐIỂM
            KẾT NỐI</h3>
    </div>
    <div>
        <button class="btn bg-vnpt text-white fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#modalThemDiem">
            <i class="bi bi-plus-circle"></i> Thêm khách hàng mới
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="py-3 text-start ps-4">Khách hàng/Địa chỉ</th>
                        <th class="py-3">Tủ cáp</th>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold text-danger">
                                <i class="bi bi-geo-alt-fill"></i> Vị trí<span class="text-danger">*</span>
                            </label>

                            <div class="input-group mb-2 shadow-sm">
                                <span class="input-group-text bg-light fw-bold text-secondary">Vĩ độ</span>
                                <input type="number" step="any" name="vi_do" id="vi_do_them"
                                    class="form-control text-primary fw-bold" required readonly>

                                <span class="input-group-text bg-light fw-bold text-secondary">Kinh độ</span>
                                <input type="number" step="any" name="kinh_do" id="kinh_do_them"
                                    class="form-control text-primary fw-bold" required readonly>
                            </div>

                            <div id="map-them" style="height: 300px; border-radius: 8px; z-index: 1;"
                                class="border border-primary shadow-sm"></div>
                            <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle"></i> Gợi ý: Có thể
                                nhấn giữ và kéo thả điểm ghim màu xanh để tinh chỉnh vị trí.</small>
                        </div>
                        <th class="py-3 text-start">Tài khoản PPPoE & Circuit ID</th>
                        <th class="py-3">Trạng thái kết nối</th>
                        <th class="py-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof danhSachDiem !=='undefined' && danhSachDiem.length> 0) { %>
                        <% danhSachDiem.forEach(function(diem) { %>
                            <tr>
                                <td class="text-start ps-4">
                                    <div class="fw-bold text-dark">
                                        <%= diem.ten_khach_hang %>
                                    </div>
                                    <div class="small text-muted"><i class="bi bi-geo-alt"></i>
                                        <%= diem.dia_chi %>
                                    </div>
                                    <div class="small text-primary"><span class="badge bg-light text-primary border">
                                            <%= diem.loai_khach_hang %>
                                        </span></div>
                                </td>

                                <td>
                                    <% if(diem.splitter_id) { %>
                                        <span class="badge bg-info text-dark fw-bold px-2 py-1"><i
                                                class="bi bi-hdd-network"></i>
                                            <%= diem.splitter_id.ten_splitter %>
                                        </span>
                                        <% } else { %>
                                            <span class="text-danger small">Chưa cắm cáp</span>
                                            <% } %>
                                </td>

                                <td class="text-start">
                                    <% if(diem.thong_tin_pppoe) { %>
                                        <div class="fw-bold text-success"><i class="bi bi-person-badge"></i> User: <%=
                                                diem.thong_tin_pppoe.username %>
                                        </div>
                                        <div class="small text-secondary" style="font-family: monospace;">
                                            <i class="bi bi-diagram-3"></i>
                                            ID: <%= diem.splitter_id ? diem.splitter_id.sys_id : 'SYS' %>/<%=
                                                    diem.thong_tin_pppoe.circuit_id.rack %>/<%=
                                                        diem.thong_tin_pppoe.circuit_id.shelf %>/<%=
                                                            diem.thong_tin_pppoe.circuit_id.slot %>/<%=
                                                                diem.thong_tin_pppoe.circuit_id.port %>
                                                                /0/33
                                        </div>
                                        <% } else { %>
                                            <span class="text-muted">Chưa cấu hình</span>
                                            <% } %>
                                </td>

                                <td>
                                    <% if(diem.trang_thai_ket_noi.mau_sac==="Xanh" ) { %>
                                        <span class="badge bg-success px-3 py-2 fs-6"><i class="bi bi-check-circle"></i>
                                            Đang hoạt động</span>
                                        <% } else if(diem.trang_thai_ket_noi.mau_sac==="Đỏ" ) { %>
                                            <span class="badge bg-danger px-3 py-2 fs-6"><i class="bi bi-x-circle"></i>
                                                Mất kết nối</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary px-3 py-2 fs-6"><i
                                                        class="bi bi-pause-circle"></i> Cần thu
                                                    hồi</span>
                                                <% } %>
                                </td>

                                <td>
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted"><i
                                                class="bi bi-inbox fs-1 d-block mb-2"></i> Chưa có khách
                                            hàng nào.</td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const mangGoiCuoc = JSON.parse("<%- JSON.stringify(typeof danhSachGoiCuoc !== 'undefined' ? danhSachGoiCuoc : []) %>");

    function capNhatGoiCuoc() {
        const loaiHinh = document.getElementById('chon_loai_hinh').value;
        const selectGoiCuoc = document.getElementById('chon_goi_cuoc');
        selectGoiCuoc.innerHTML = '<option value="">-- Chọn gói cước --</option>';

        if (!loaiHinh) return;
        const danhSachLoc = mangGoiCuoc.filter(gc => gc.loai_hinh_thue_bao && gc.loai_hinh_thue_bao.includes(loaiHinh));

        danhSachLoc.forEach(gc => {
            const option = document.createElement('option');
            option.value = gc.id;
            option.textContent = gc.ten_goi_cuoc;
            selectGoiCuoc.appendChild(option);
        });
    }

    let mapThem;
    let markerThem;

    document.getElementById('modalThemDiem').addEventListener('shown.bs.modal', function () {

        if (!mapThem) {
            const defaultLat = 10.3759;
            const defaultLng = 105.4333;

            mapThem = L.map('map-them').setView([defaultLat, defaultLng], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(mapThem);

            markerThem = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(mapThem);

            document.getElementById('vi_do_them').value = defaultLat;
            document.getElementById('kinh_do_them').value = defaultLng;
            mapThem.on('click', function (e) {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;
                
                markerThem.setLatLng([lat, lng]);
                
                document.getElementById('vi_do_them').value = lat;
                document.getElementById('kinh_do_them').value = lng;
            });
            markerThem.on('dragend', function (e) {
                const position = markerThem.getLatLng();
                document.getElementById('vi_do_them').value = position.lat;
                document.getElementById('kinh_do_them').value = position.lng;
            });
            
        } else {
            mapThem.invalidateSize();
        }
    });
</script>