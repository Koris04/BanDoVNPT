<div class="d-flex justify-content-center align-items-center w-100" style="min-height: 65vh;">
    <div class="text-center p-5 bg-white shadow border-0 rounded-4"
        style="max-width: 600px; border-top: 6px solid #dc3545 !important;">

        <i class="bi bi-database-fill-x text-danger mb-3" style="font-size: 5rem;"></i>

        <h2 class="fw-bold text-dark mt-2">Lỗi kết nối với máy chủ</h2>

        <p class="text-muted fs-5 mt-3 mb-4 px-3">
            <%= typeof errorMsg !=='undefined' ? errorMsg
                : 'Hệ thống đang gặp sự cố khi kết nối đến Cơ sở dữ liệu. Vui lòng thử lại sau ít phút.' %>
        </p>

        <a href="/" class="btn bg-vnpt text-white fw-bold px-4 py-2 rounded-pill shadow-sm">
            <i class="bi bi-house-door"></i> Trở về trang chủ
        </a>
        <button onclick="window.location.reload();"
            class="btn btn-outline-secondary fw-bold px-4 py-2 rounded-pill shadow-sm ms-2">
            <i class="bi bi-arrow-clockwise"></i> Thử lại
        </button>
    </div>
</div>